APP_NAME=Fidge
APP_ENV=production
APP_KEY=base64:YOUR_KEY_HERE_USE_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://fidge-email-production.up.railway.app

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── MySQL (Railway) ───────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# ── CORS — must be your exact Vercel URL, no trailing slash ──────────────────
FRONTEND_URL=https://fidge-email.vercel.app
EXTRA_ORIGINS=

# ── Mail (OTP codes sent via email) ──────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=in-v3.mailjet.com
MAIL_PORT=587
MAIL_USERNAME=your_mailjet_api_key
MAIL_PASSWORD=your_mailjet_secret_key
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="Fidge"

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
ADMIN_USERNAME_2=fidge_op
ADMIN_PASSWORD_2=change-me-strong-password-2

# ── Cache / Queue ─────────────────────────────────────────────────────────────
CACHE_STORE=database
QUEUE_CONNECTION=database

# ── Marketplace ──────────────────────────────────────────────────────────────
ETH_WALLET_ADDRESS=0xYourEthereumWalletAddressHere
ETH_PRICE_USD=3000

# Admin 2FA
ADMIN_TOTP_SECRET=BASE32SECRETHERE
